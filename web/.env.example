# --- Payload ---
# Generate a long random string for production: `openssl rand -base64 32`
PAYLOAD_SECRET=change-me-to-a-long-random-string
# Local dev uses SQLite (file-based). Swap to Postgres in production (see payload.config.ts).
DATABASE_URI=file:./oneworld.db

# Public site URL (used for canonical/hreflang/sitemap and email links)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Enquiry email (optional in dev) ---
# If unset, Payload logs emails to the console instead of sending them.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="One World <no-reply@oneworld.ge>"
# Where enquiry notifications are sent (One World staff inbox)
ENQUIRY_NOTIFY_TO=info@oneworld.ge

# --- Spam protection (Cloudflare Turnstile) ---
# If unset, Turnstile verification is skipped in dev (honeypot still active).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Analytics (optional) ---
# Set your domain to enable privacy-friendly Plausible analytics.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- Contact channels (surfaced in UI) ---
NEXT_PUBLIC_WHATSAPP_NUMBER=995500000000
NEXT_PUBLIC_PHONE_NUMBER=+995322000000
NEXT_PUBLIC_CONTACT_EMAIL=info@oneworld.ge
